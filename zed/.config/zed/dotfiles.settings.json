{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "completion_provider": "copilot",
  "edit_predictions": {
    "provider": "copilot"
  },
  "auto_install_extensions": {
    "tokyo-night": true
  },
  "inline_completion_provider": "copilot",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    }
  },
  "git_panel": {
    "dock": "left"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "theme": {
    "mode": "system",
    "light": "Tokyo Night Day",
    "dark": "Tokyo Night"
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 15
  }
}
