{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "completion_provider": "copilot",
  "edit_predictions": {
    "provider": "copilot"
  },
  "default_model": "auto",
  "inline_completion_provider": "copilot",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "default_model": "auto",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "git": {
    "commit_message_provider": "copilot"
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
    "font_size": 15
  }
}
